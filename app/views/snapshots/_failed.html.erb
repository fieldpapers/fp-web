<div class="row">
  <div class="eight columns">
    <div class="row">
      <div class="twelve columns">
        <h2><%= _("Snapshot Processing Failed (%{image_filename})") % {image_filename: snapshot.image_filename} %></h2>
      </div>
    </div>
    <div class="row">
      <div class="twelve columns">
        <p><%= _("Unfortunately, your snapshot for image %{image_filename} failed to be processed. It's possible that it was an intermittent error, in which case you should try re-uploading. If the problem persists, please %{open_issue} with details.") % { open_issue: link_to(_("open a GitHub issue"), "https://github.com/fieldpapers/fieldpapers/issues/"), image_filename: snapshot.image_filename } %></p>
      </div>
    </div>
  </div>
</div>
